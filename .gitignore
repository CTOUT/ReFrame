# Agent profile cache (generated at runtime)
.github/agents/.cache/

# system-scan skill exports — DxDiag and msinfo32 files dropped into the repo
# The skill writes its temp file to $env:TEMP (outside the repo), but users
# may also place exported files here for use with `load dxdiag <path>`.
DxDiag.xml
DxDiag.txt
msinfo32.txt
Temp/

# VS Code local settings
.vscode/*
!.vscode/extensions.json

# OS artefacts
.DS_Store
Thumbs.db
desktop.ini

# Node (tooling)
node_modules/
npm-debug.log*
*.log

# Release build output
dist/

# PowerShell transcripts
Transcript*
*.pslog

# Temp / scratch files
*.tmp
*.bak
*.swp
Temp/

# ReFrame runtime backups (stored locally, not committed)
backups/
